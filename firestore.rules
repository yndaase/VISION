rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ═══════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════
    
    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if user is accessing their own document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Check if user email matches
    function isOwnerByEmail(email) {
      return isSignedIn() && request.auth.token.email == email;
    }
    
    // Check if user is admin
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Check if user is enterprise admin
    function isEnterpriseAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'enterprise';
    }
    
    // Check if user is teacher
    function isTeacher() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }
    
    // Check if user is enterprise student
    function isEnterpriseStudent() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'enterprise-student';
    }
    
    // Check if user belongs to the same institution
    function sameInstitution(institutionId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId == institutionId;
    }
    
    // Check if user has any enterprise role (admin, teacher, or student)
    function hasEnterpriseRole() {
      return isEnterpriseAdmin() || isTeacher() || isEnterpriseStudent();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // USERS COLLECTION
    // ═══════════════════════════════════════════════════════════════
    
    match /users/{userId} {
      // Anyone can read their own user document
      allow read: if isOwner(userId);
      
      // Users can update their own document (except role changes)
      allow update: if isOwner(userId) && 
                       (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      
      // Admins can read and write all users
      allow read, write: if isAdmin();
      
      // Enterprise admins can read users from their institution
      allow read: if isEnterpriseAdmin() && 
                     sameInstitution(resource.data.institutionId);
      
      // Enterprise admins can create users in their institution
      allow create: if isEnterpriseAdmin() && 
                       request.resource.data.institutionId == 
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId;
      
      // Enterprise admins can update users in their institution (except role changes to admin)
      allow update: if isEnterpriseAdmin() && 
                       sameInstitution(resource.data.institutionId) &&
                       request.resource.data.institutionId == resource.data.institutionId &&
                       request.resource.data.role != 'admin';
      
      // Teachers can read students from their institution
      allow read: if isTeacher() && 
                     sameInstitution(resource.data.institutionId) &&
                     resource.data.role == 'enterprise-student';
    }
    
    // ═══════════════════════════════════════════════════════════════
    // MATERIALS COLLECTION
    // ═══════════════════════════════════════════════════════════════
    
    match /materials/{materialId} {
      // Anyone authenticated can read public materials (no institutionId)
      allow read: if isSignedIn() && !('institutionId' in resource.data);
      
      // Enterprise students can read materials from their institution
      allow read: if isEnterpriseStudent() && 
                     sameInstitution(resource.data.institutionId);
      
      // Teachers can read materials from their institution
      allow read: if isTeacher() && 
                     sameInstitution(resource.data.institutionId);
      
      // Enterprise admins can read/write materials for their institution
      allow read, write: if isEnterpriseAdmin() && 
                            sameInstitution(resource.data.institutionId);
      
      // System admins can read/write all materials
      allow read, write: if isAdmin();
      
      // Teachers can create materials for their institution
      allow create: if isTeacher() && 
                       request.resource.data.institutionId == 
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId;
      
      // Teachers can update/delete materials they created
      allow update, delete: if isTeacher() && 
                               resource.data.uploadedBy == request.auth.token.email &&
                               sameInstitution(resource.data.institutionId);
    }
    
    // ═══════════════════════════════════════════════════════════════
    // QUIZZES COLLECTION
    // ═══════════════════════════════════════════════════════════════
    
    match /quizzes/{quizId} {
      // Anyone authenticated can read public quizzes
      allow read: if isSignedIn() && !('institutionId' in resource.data);
      
      // Enterprise students can read quizzes from their institution
      allow read: if isEnterpriseStudent() && 
                     sameInstitution(resource.data.institutionId);
      
      // Teachers can read/write quizzes for their institution
      allow read, write: if isTeacher() && 
                            sameInstitution(resource.data.institutionId);
      
      // Enterprise admins can read/write quizzes for their institution
      allow read, write: if isEnterpriseAdmin() && 
                            sameInstitution(resource.data.institutionId);
      
      // System admins can read/write all quizzes
      allow read, write: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // GRADES COLLECTION
    // ═══════════════════════════════════════════════════════════════
    
    match /grades/{gradeId} {
      // Students can read their own grades
      allow read: if isSignedIn() && 
                     resource.data.studentEmail == request.auth.token.email;
      
      // Teachers can read/write grades for students in their institution
      allow read, write: if isTeacher() && 
                            sameInstitution(resource.data.institutionId);
      
      // Enterprise admins can read/write grades for their institution
      allow read, write: if isEnterpriseAdmin() && 
                            sameInstitution(resource.data.institutionId);
      
      // System admins can read/write all grades
      allow read, write: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // CLASSES COLLECTION
    // ═══════════════════════════════════════════════════════════════
    
    match /classes/{classId} {
      // Enterprise students can read classes they belong to
      allow read: if isEnterpriseStudent() && 
                     request.auth.token.email in resource.data.students;
      
      // Teachers can read/write classes in their institution
      allow read, write: if isTeacher() && 
                            sameInstitution(resource.data.institutionId);
      
      // Enterprise admins can read/write classes for their institution
      allow read, write: if isEnterpriseAdmin() && 
                            sameInstitution(resource.data.institutionId);
      
      // System admins can read/write all classes
      allow read, write: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // ASSIGNMENTS COLLECTION
    // ═══════════════════════════════════════════════════════════════
    
    match /assignments/{assignmentId} {
      // Students can read assignments assigned to them
      allow read: if isEnterpriseStudent() && 
                     request.auth.token.email in resource.data.assignedTo;
      
      // Students can create submissions for their assignments
      allow create: if isEnterpriseStudent() && 
                       request.auth.token.email in 
                       get(/databases/$(database)/documents/assignments/$(assignmentId)).data.assignedTo;
      
      // Teachers can read/write assignments for their institution
      allow read, write: if isTeacher() && 
                            sameInstitution(resource.data.institutionId);
      
      // Enterprise admins can read/write assignments for their institution
      allow read, write: if isEnterpriseAdmin() && 
                            sameInstitution(resource.data.institutionId);
      
      // System admins can read/write all assignments
      allow read, write: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // ANNOUNCEMENTS COLLECTION
    // ═══════════════════════════════════════════════════════════════
    
    match /announcements/{announcementId} {
      // Anyone authenticated can read public announcements
      allow read: if isSignedIn() && !('institutionId' in resource.data);
      
      // Enterprise users can read announcements for their institution
      allow read: if hasEnterpriseRole() && 
                     sameInstitution(resource.data.institutionId);
      
      // Teachers can create announcements for their institution
      allow create: if isTeacher() && 
                       request.resource.data.institutionId == 
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId;
      
      // Enterprise admins can read/write announcements for their institution
      allow read, write: if isEnterpriseAdmin() && 
                            sameInstitution(resource.data.institutionId);
      
      // System admins can read/write all announcements
      allow read, write: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // STATS COLLECTION (User Progress)
    // ═══════════════════════════════════════════════════════════════
    
    match /stats/{userId} {
      // Users can read/write their own stats
      allow read, write: if isOwner(userId);
      
      // Teachers can read stats for students in their institution
      allow read: if isTeacher() && 
                     sameInstitution(
                       get(/databases/$(database)/documents/users/$(userId)).data.institutionId
                     );
      
      // Enterprise admins can read stats for their institution
      allow read: if isEnterpriseAdmin() && 
                     sameInstitution(
                       get(/databases/$(database)/documents/users/$(userId)).data.institutionId
                     );
      
      // System admins can read all stats
      allow read: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // INSTITUTIONS COLLECTION
    // ═══════════════════════════════════════════════════════════════
    
    match /institutions/{institutionId} {
      // Enterprise users can read their own institution
      allow read: if hasEnterpriseRole() && 
                     sameInstitution(institutionId);
      
      // Enterprise admins can update their institution
      allow update: if isEnterpriseAdmin() && 
                       sameInstitution(institutionId);
      
      // System admins can read/write all institutions
      allow read, write: if isAdmin();
    }
    
    // ═══════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════════════════════
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
