# Claude Code Ignore File
# Ignore dependencies
node_modules/
bower_components/
jspm_packages/

# Ignore build outputs
dist/
build/
out/
.next/
.nuxt/
.cache/

# Ignore version control and IDE files
.git/
.svn/
.hg/
.vscode/
.idea/
*.swp
*.swo

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Ignore large binary files or media
assets/
images/
videos/
audio/
fonts/
*.pdf
*.zip
*.tar.gz

# Ignore local environment files
.env*
.claude/
